<Window x:Class="Transporturi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adăugare Șofer"
        Height="500"
        Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#F2F2F2">

    <Grid Margin="30">

        <Border Background="White"
                CornerRadius="20"
                Padding="25">

            <StackPanel>

                <TextBlock Text="Adăugare Șofer"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="0 0 0 25"
                           Foreground="#1F3D2B"/>

                <TextBlock Text="Nume"/>
                <TextBox x:Name="txtNume"
                         Height="35"
                         Margin="0 5 0 15"/>

                <TextBlock Text="Categorii Permis"/>
                <TextBox x:Name="txtCategorii"
                         Height="35"
                         Margin="0 5 0 15"/>

                <TextBlock Text="Kilometri"/>
                <TextBox x:Name="txtKilometri"
                         Height="35"
                         Margin="0 5 0 20"/>

                <Button Content="Adaugă Șofer"
                        Height="45"
                        Width="180"
                        Background="#1F3D2B"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="BtnAdauga_Click"/>

                <TextBlock x:Name="txtMesaj"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0 20 0 0"/>
            </StackPanel>

        </Border>

    </Grid>
</Window>