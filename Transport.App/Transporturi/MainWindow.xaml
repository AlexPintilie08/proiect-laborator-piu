<Window x:Class="Transporturi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Management Mașini - Lab 10"
        Height="650"
        Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#F2F2F2">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0 8 0 0"/>
            <Setter Property="Background" Value="#1F3D2B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="0 4 0 10"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="0 4 0 10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="1.8*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0 0 20 0">
            <TextBlock Text="CRUD Mașină"
                       FontSize="26"
                       FontWeight="Bold"
                       Margin="0 0 0 20"/>

            <TextBlock Text="Număr înmatriculare"/>
            <TextBox Text="{Binding MasinaCurenta.Numar, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Marcă"/>
            <TextBox Text="{Binding MasinaCurenta.Marca, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="An fabricație"/>
            <TextBox Text="{Binding MasinaCurenta.AnFabricatie, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Kilometri"/>
            <TextBox Text="{Binding MasinaCurenta.Kilometri, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Culoare"/>
            <ComboBox ItemsSource="{Binding Culori}"
                      SelectedItem="{Binding MasinaCurenta.Culoare, Mode=TwoWay}"/>

            <Button Content="Create / Adaugă"
                    Click="BtnCreate_Click"/>

            <Button Content="Update / Modifică"
                    Click="BtnUpdate_Click"/>

            <Button Content="Delete / Șterge"
                    Click="BtnDelete_Click"/>

            <TextBlock Text="{Binding Mesaj}"
                       FontSize="15"
                       FontWeight="Bold"
                       Margin="0 15 0 0"
                       Foreground="#1F3D2B"/>
        </StackPanel>

        <StackPanel Grid.Column="1">
            <TextBlock Text="Lista mașinilor"
                       FontSize="26"
                       FontWeight="Bold"
                       Margin="0 0 0 20"/>

            <ListBox ItemsSource="{Binding Masini}"
                     SelectedItem="{Binding MasinaSelectata, Mode=TwoWay}"
                     Height="430"/>

            <TextBlock Text="Preview binding către TextBox:"
                       Margin="0 15 0 5"
                       FontWeight="Bold"/>

            <TextBlock Text="{Binding MasinaCurenta.Marca}"
                       FontSize="18"
                       Foreground="#1F3D2B"/>
        </StackPanel>
    </Grid>
</Window>