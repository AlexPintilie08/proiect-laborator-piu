<Window x:Class="Transporturi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Management Transporturi"
        Height="650"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F2F2F2">

    <Window.Resources>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#1F3D2B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0 10 0 0"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="0 5 0 15"/>
        </Style>

    </Window.Resources>

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="Fișier">
                <MenuItem Header="Ieșire"
                          Click="Exit_Click"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Margin="0 0 20 0">

                <TextBlock Text="Adăugare Șofer"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0 0 0 20"/>

                <TextBlock Text="Nume"/>
                <TextBox x:Name="txtNume"/>

                <TextBlock Text="Telefon"/>
                <TextBox x:Name="txtTelefon"/>

                <TextBlock Text="Categorii Permis"/>
                <TextBox x:Name="txtCategorii"/>

                <TextBlock Text="Kilometri"/>
                <TextBox x:Name="txtKilometri"/>

                <TextBlock Text="Tip Angajat"
                           Margin="0 10 0 5"/>

                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="rbIntern"
                                 Content="Intern"
                                 Margin="0 0 20 0"/>
                    <RadioButton x:Name="rbExtern"
                                 Content="Extern"/>
                </StackPanel>

                <TextBlock Text="Beneficii"
                           Margin="0 15 0 5"/>

                <CheckBox x:Name="cbBonus"
                          Content="Prime Bonus"/>

                <CheckBox x:Name="cbAsigurare"
                          Content="Asigurare Medicală"/>

                <Button Content="Adaugă"
                        Click="BtnAdauga_Click"/>

                <TextBlock x:Name="txtMesaj"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0 15 0 0"/>

            </StackPanel>

            <StackPanel Grid.Column="1">

                <TextBlock Text="Căutare Șofer"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0 0 0 20"/>

                <TextBlock Text="Nume"/>

                <TextBox x:Name="txtCautare"/>

                <Button Content="Caută"
                        Width="150"
                        Click="BtnCauta_Click"/>

                <ListBox x:Name="lstSoferi"
                         Margin="0 20 0 0"/>

            </StackPanel>

        </Grid>

    </Grid>
</Window>