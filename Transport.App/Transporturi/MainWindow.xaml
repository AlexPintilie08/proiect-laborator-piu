<Window x:Class="Transporturi.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Management Transporturi"
        Height="450"
        Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#F2F2F2">

    <Grid Margin="30">
        <Border Background="White"
                CornerRadius="18"
                Padding="25"
                BorderBrush="#D0D0D0"
                BorderThickness="1">

            <StackPanel>
                <TextBlock Text="Management Transporturi"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#1F3D2B"
                           Margin="0 0 0 20"/>

                <TextBlock Text="Informații șofer"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0 0 0 15"/>

                <TextBlock x:Name="TxtId"
                           FontSize="16"
                           Margin="0 6"/>

                <TextBlock x:Name="TxtNume"
                           FontSize="16"
                           Margin="0 6"/>

                <TextBlock x:Name="TxtCategorii"
                           FontSize="16"
                           Margin="0 6"/>

                <TextBlock x:Name="TxtKilometri"
                           FontSize="16"
                           Margin="0 6"/>

                <Button Content="Actualizează date"
                        Width="180"
                        Height="40"
                        Margin="0 25 0 0"
                        HorizontalAlignment="Left"
                        Background="#1F3D2B"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="BtnActualizeaza_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>